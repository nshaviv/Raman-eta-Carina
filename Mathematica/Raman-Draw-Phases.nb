          RowBox[{"Arrowheads", "[", "Medium", "]"}], ",", 
          RowBox[{"Thickness", "[", "th", "]"}], ",", 
          RowBox[{"Arrow", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"p1", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "+", 
                RowBox[{
                 RowBox[{"Cos", "[", "\[Alpha]", "]"}], "l"}]}], ",", 
               RowBox[{
                RowBox[{"p1", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "+", 
                RowBox[{
                 RowBox[{"Sin", "[", "\[Alpha]", "]"}], "l"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"p1", "[", 
