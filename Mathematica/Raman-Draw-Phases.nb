Cell[BoxData[
 RowBox[{
  RowBox[{"WigglyArrow", "[", 
   RowBox[{
   "p1_", ",", "\[Alpha]_", ",", "l_", ",", "n_", ",", "sy_", ",", "ps_", ",",
     "th_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xs", " ", "=", 
      RowBox[{"l", " ", 
       RowBox[{"Table", "[", 
        RowBox[{"i", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "1", ",", 
           RowBox[{"1", "/", "ps"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ys", " ", "=", " ", 
      RowBox[{"Table", "[", " ", 
       RowBox[{
        RowBox[{"sy", " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"2", "\[Pi]", " ", "n", "  ", "i"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "1", ",", 
          RowBox[{"1", "/", "ps"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{
              RowBox[{"Cos", "[", "\[Alpha]", "]"}], "xs"}], "-", 
             RowBox[{
              RowBox[{"Sin", "[", "\[Alpha]", "]"}], "ys"}]}], ",", 
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "+", 
             RowBox[{
              RowBox[{"Sin", "[", "\[Alpha]", "]"}], "xs"}], "+", 
             RowBox[{
              RowBox[{"Cos", "[", "\[Alpha]", "]"}], "ys"}]}]}], "}"}], "]"}],
          ",", 
         RowBox[{"Joined", "\[Rule]", "True"}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
         RowBox[{"Axes", "->", "None"}], ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Black", ",", 
            RowBox[{"Thickness", "[", "th", "]"}]}], "]"}]}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
