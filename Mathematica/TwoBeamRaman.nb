Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Log", "[", 
      RowBox[{"10", ",", "RamanReflect"}], "]"}], " ", "//.", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Iin", " ", "\[Rule]", "1"}], " ", ",", " ", 
       RowBox[{"\[Sigma]H", "\[Rule]", 
        RowBox[{
         RowBox[{"10", "^", "pr"}], " ", "\[Sigma]L"}]}], " ", ",", " ", 
       RowBox[{"\[Sigma]L", "\[Rule]", 
        RowBox[{"6", " ", "\[Kappa]"}]}], ",", 
       RowBox[{"d", "\[Rule]", "1"}]}], "}"}]}], "/.", " ", 
    RowBox[{"\[Kappa]", "\[Rule]", 
     RowBox[{"10", "^", "p\[Kappa]"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{"p\[Kappa]", ",", 
     RowBox[{"-", "2"}], ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"pr", ",", 
     RowBox[{"-", "3"}], ",", "1"}], "}"}], ",", 
   RowBox[{"Contours", "\[Rule]", "10"}]}], "]"}]], "Input",
