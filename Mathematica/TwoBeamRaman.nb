Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "We", " ", "see", " ", "from", " ", "the", " ", "above", " ", "that", " ", 
    "once", " ", "the", " ", "optical", " ", "depth", " ", "is", " ", "large",
     " ", "for", " ", "the", " ", "H\[Alpha]", " ", "scattering"}], ",", " ", 
   
   RowBox[{
   "then", " ", "the", " ", "reflection", " ", "increases", " ", "by", " ", 
    "a", " ", "factor", " ", "of", " ", "2", " ", "and", " ", "whatever", " ",
     "passes", " ", "through", " ", "decreases", " ", "like", " ", 
    RowBox[{"1", "/", "optical"}], " ", "depth"}]}], " ", "*)"}]], "Input",
